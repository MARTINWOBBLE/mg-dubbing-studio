# OpenRouter API-nøkkel (valgfritt – kun for Gemini-oversettelse og premium-stemmer)
OPENROUTER_API_KEY=

# Sti til FFmpeg sin bin-katalog (valgfritt hvis ffmpeg allerede er på PATH)
# Eksempel Windows: C:\ffmpeg\bin   ·   Linux/Mac: /usr/bin
FFMPEG_PATH=

# Valgfri overstyring av modeller
# ASR_MODEL=NbAiLab/nb-whisper-medium-beta
# MT_MODEL=Helsinki-NLP/opus-mt-no-sv
# OPENROUTER_TRANSLATE_MODEL=google/gemini-2.0-flash-001
